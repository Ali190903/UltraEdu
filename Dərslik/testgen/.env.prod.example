# === PRODUCTION ENVIRONMENT ===
# Copy to .env.prod and fill in real values
#
# docker compose üçün DB şifrəsi və s. interpolate olunmalıdır, məsələn:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# və ya POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB-i shell-də export edin.

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL
POSTGRES_USER=testgen
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=testgen
DATABASE_URL=postgresql+asyncpg://testgen:CHANGE_TO_STRONG_PASSWORD@db:5432/testgen
DATABASE_URL_SYNC=postgresql://testgen:CHANGE_TO_STRONG_PASSWORD@db:5432/testgen

# Qdrant (internal Docker network)
QDRANT_URL=http://qdrant:6333

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_TO_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# IMPORTANT: Must be true in production (HTTPS only cookies)
COOKIE_SECURE=true

# Frontend — keep EMPTY so browser uses relative URLs through nginx
NEXT_PUBLIC_API_URL=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — your production domain (no trailing slash)
CORS_ORIGINS=https://e-tehsil.me,https://www.e-tehsil.me

# Generation settings
SIMILARITY_THRESHOLD=0.85
MAX_GENERATION_ATTEMPTS=3
