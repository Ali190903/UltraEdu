# === PRODUCTION ENVIRONMENT ===
# Copy to .env.prod and fill in real values

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL
POSTGRES_USER=testgen
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=testgen
DATABASE_URL=postgresql+asyncpg://testgen:CHANGE_TO_STRONG_PASSWORD@db:5432/testgen
DATABASE_URL_SYNC=postgresql://testgen:CHANGE_TO_STRONG_PASSWORD@db:5432/testgen

# Qdrant (internal Docker network)
QDRANT_URL=http://qdrant:6333

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_TO_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Frontend URL (used for CORS, set to your DigitalOcean droplet IP or domain)
# e.g. http://161.35.123.45 or https://testgen.az
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP_OR_DOMAIN

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — comma-separated list of allowed origins
# e.g. http://161.35.123.45,https://testgen.az
CORS_ORIGINS=http://YOUR_DROPLET_IP_OR_DOMAIN

# Generation settings
SIMILARITY_THRESHOLD=0.85
MAX_GENERATION_ATTEMPTS=3
